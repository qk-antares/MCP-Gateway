{
  "permissions": {
    "allow": [
      "Read *",
      "Glob *",
      "Grep *",
      "Write *",
      "Edit *",
      "Bash *",
      "Bash(mcp2cli *)",
      "Bash(sh *)",
      "Bash(chmod +x *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/mcp-sync.sh",
            "timeout": 120
          }
        ]
      }
    ]
  },
  "allowedMcpServers": []
}
