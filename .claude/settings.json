{
  "permissions": {
    "allow": [
      "Read *",
      "Glob *",
      "Grep *",
      "Write *",
      "Edit *",
      "Bash *",
      "Bash(mcp2cli *)",
      "Bash(sh *)",
      "Bash(chmod +x *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'test -f .claude/skills/mcp-manager/scripts/sync.sh && sh .claude/skills/mcp-manager/scripts/sync.sh . || true'",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "allowedMcpServers": []
}
