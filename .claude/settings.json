{
  "permissions": {
    "allow": [
      "Read *",
      "Glob *",
      "Grep *",
      "Write *",
      "Edit *",
      "Bash *",
      "Bash(mcp2cli *)",
      "Bash(sh *)",
      "Bash(chmod +x *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "sh .claude/hooks/session-start-mcp-sync.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "/User/qiankun/.mcp-manager.json",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/on-tools-md-changed.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp-manager.json",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/on-tools-md-changed.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "allowedMcpServers": []
}
